pipeline {

    agent any

    environment {
        DOCKER_IMAGE = "bhavichith/simple-ci-cd-app"
    }

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/baviamu/simple-ci-cd-app.git'
            }
        }

        stage('Install Dependencies') {
    steps {
        sh '''
        python3 -m venv venv
        ./venv/bin/pip install -r requirements.txt
        '''
    }
}

        stage('Test') {
            steps {
                sh 'pytest'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                    sonar-scanner \
                    -Dsonar.projectKey=simple-ci-cd-app \
                    -Dsonar.sources=. \
                    -Dsonar.host.url=http://3.109.182.165:9000 \
                    -Dsonar.login=$SONAR_AUTH_TOKEN
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 1, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE .'
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                credentialsId: 'dockerhub-creds',
                usernameVariable: 'USER',
                passwordVariable: 'PASS'
                )]) {

                sh '''
                echo $PASS | docker login -u $USER --password-stdin
                docker push $DOCKER_IMAGE
                '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker stop simple-container || true
                docker rm simple-container || true
                docker run -d -p 5000:5000 --name simple-container $DOCKER_IMAGE
                '''
            }
        }
    }
}
