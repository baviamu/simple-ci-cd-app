pipeline {

    agent any

    environment {
        DOCKER_IMAGE = "bhavichith/simple-ci-cd-app"
    }

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/baviamu/simple-ci-cd-app.git'
            }
        }

        stage('Install Dependencies') {
    steps {
        sh '''
        python3 -m venv venv
        . venv/bin/activate
        pip install -r requirements.txt
        '''
    }
}

        stage('Test') {
    steps {
        sh './venv/bin/pytest'
    }
}

       stage('SonarQube Analysis') {
    steps {
        withSonarQubeEnv('sonar') {
            sh '''
            /opt/sonar-scanner/bin/sonar-scanner \
            -Dsonar.projectKey=simple-ci-cd-app \
            -Dsonar.sources=. \
            -Dsonar.exclusions=venv/**
            '''
        }
    }
}
        stage('Quality Gate') {
    steps {
        timeout(time: 10, unit: 'MINUTES') {
            waitForQualityGate abortPipeline: false
        }
    }
}
        stage('Docker Build') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE .'
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                credentialsId: 'dockerhub-creds',
                usernameVariable: 'USER',
                passwordVariable: 'PASS'
                )]) {

                sh '''
                echo $PASS | docker login -u $USER --password-stdin
                docker push $DOCKER_IMAGE
                '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker stop simple-container || true
                docker rm simple-container || true
                docker run -d -p 5000:5000 --name simple-container $DOCKER_IMAGE
                '''
            }
        }
    }
}
